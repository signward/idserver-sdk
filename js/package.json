{
  "name": "@signward/idserver-client",
  "version": "1.0.0",
  "description": "JavaScript / TypeScript client SDK for Signward Identity Server — OIDC authentication for Node.js, Express, and the browser.",
  "license": "MIT",
  "author": "Signward",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "test:js": "npm run build && node --test dist-tests/**/*.test.js",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "authentication",
    "identity",
    "oidc",
    "oauth2",
    "jwt",
    "signward",
    "express",
    "sso"
  ],
  "repository": "https://developer.signward.com",
  "homepage": "https://signward.com",
  "bugs": {
    "email": "support@signward.com"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "jose": "^5.9.0"
  },
  "peerDependencies": {
    "express": ">=4.18.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "express": "^4.19.2",
    "typescript": "^5.5.0"
  }
}
